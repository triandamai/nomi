  "query": "\n        SELECT cm.conversation_id as \"conversation_id!\", conv.title, cm.joined_at as \"joined_at!\"\n        FROM conversation_members cm\n        JOIN conversations conv ON cm.conversation_id = conv.id\n        WHERE cm.user_id = $1\n        ",
