  "db_name": "PostgreSQL",
  "query": "\n        SELECT id,\n               conversation_id as \"conversation_id!\",\n               role,\n               content,\n               thought,\n               user_id,\n               created_at as \"created_at!\",\n               total_tokens,\n               answer_tokens,\n               prompt_tokens\n        FROM messages\n        WHERE conversation_id = $1 AND created_at < $2\n        ORDER BY created_at DESC\n        LIMIT $3\n        ",
