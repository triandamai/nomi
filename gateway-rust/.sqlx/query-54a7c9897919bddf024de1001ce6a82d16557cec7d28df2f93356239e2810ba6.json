{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT \n            id,\n            task_type as \"task_type!\",\n            payload as \"payload!\",\n            COALESCE(payload->>'message', content) as \"content!\",\n            (due_at AT TIME ZONE 'Asia/Jakarta') as due_at,\n            frequency,\n            status,\n            created_at\n        FROM reminders\n        WHERE user_id = $1\n        ORDER BY due_at ASC\n        ",
