  "query": "\n        SELECT id, conversation_id as \"conversation_id!\", role, content, thought, user_id, created_at as \"created_at!\"\n        FROM messages\n        WHERE conversation_id = $1 AND created_at < $2\n        ORDER BY created_at DESC\n        LIMIT $3\n        ",
