{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT c.id, c.title, c.created_at, c.updated_at,c.max_token_usage, c.cumulative_tokens\n        FROM conversations c\n        INNER JOIN conversation_members cm ON c.id = cm.conversation_id\n        WHERE cm.user_id = $1\n        ORDER BY c.updated_at DESC\n        LIMIT 50\n        ",
