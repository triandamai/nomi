{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id, u.name, u.display_name, u.email\n        FROM friendships f\n        JOIN users u ON (f.user_id_1 = u.id AND f.user_id_2 = $1) OR (f.user_id_2 = u.id AND f.user_id_1 = $1)\n        ORDER BY COALESCE(u.display_name, u.name) ASC\n        ",
