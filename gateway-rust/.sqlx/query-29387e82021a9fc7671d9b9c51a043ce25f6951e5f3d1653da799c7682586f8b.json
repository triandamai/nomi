  "query": "\n        SELECT r.id, r.user_id, r.conversation_id, r.content, r.due_at, \n               r.frequency, r.interval_count, r.max_repeats, r.current_runs\n        FROM reminders r\n        WHERE r.status = 'pending' AND r.due_at <= NOW()\n        LIMIT 20\n        ",
